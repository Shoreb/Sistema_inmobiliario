# URL de conexión a Supabase (PostgreSQL)
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.XXXXXX.supabase.co:5432/postgres

# Clave secreta para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_una_clave_muy_segura_y_larga

# Puerto (Railway lo asigna automáticamente, no cambiar)
PORT=8000

# Email (opcional — solo si quieres enviar correos)
EMAIL_USER=
EMAIL_PASS=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
